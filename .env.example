NODE_ENV=development
APP_PUBLIC_URL=http://localhost:3000
WEB_PORT=3000
API_PORT=4000

DATABASE_URL=mysql://option_decode:option_decode@127.0.0.1:3308/option_decode
REDIS_URL=redis://127.0.0.1:6380/0

SESSION_SECRET=change-me-before-production
JWT_SECRET=change-me-before-production

DHAN_CLIENT_ID=your_client_id
DHAN_ACCESS_TOKEN=your_access_token
DHAN_API_BASE_URL=https://api.dhan.co

MARKET_TIMEZONE=Asia/Kolkata
FEED_UNDERLYINGS=NIFTY,BANKNIFTY,FINNIFTY,MIDCPNIFTY,NIFTYNXT50,SENSEX,BANKEX,CRUDEOIL,NATURALGAS,COPPER,SILVER
SNAPSHOT_INTERVAL_MS=30000
# Optional BullMQ cron pattern. If set, this overrides SNAPSHOT_INTERVAL_MS.
# Example: every 30 seconds
# SNAPSHOT_CRON_PATTERN=*/30 * * * * *
SNAPSHOT_RETENTION_DAYS=90
SNAPSHOT_RETENTION_CRON_PATTERN=0 30 1 * * *
SNAPSHOT_RETENTION_BATCH_SIZE=500
MOCK_MARKET_FEED_ENABLED=true

# Browser push notifications for critical alerts. Generate with:
# pnpm --filter @option-decode/worker exec web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:info@pytrade.co.in

# Transactional email for verification and password reset.
# Configure these before enabling public registration in production.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=Option Decode <no-reply@pytrade.co.in>
