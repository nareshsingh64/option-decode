NODE_ENV=production
APP_PUBLIC_URL=https://pytrade.co.in
WEB_PORT=3000
API_PORT=4000

# MySQL runs natively on the EC2 host (not in Docker) as of the native-MySQL
# migration. host.docker.internal resolves to the host via the extra_hosts
# entry in docker-compose.prod.yml (Docker 20.10+ on Linux).
DATABASE_URL=mysql://option_decode:CHANGE_ME_DB_PASSWORD@host.docker.internal:3306/option_decode
REDIS_URL=redis://redis:6379/0

MYSQL_DATABASE=option_decode
MYSQL_USER=option_decode
MYSQL_PASSWORD=CHANGE_ME_DB_PASSWORD

SESSION_SECRET=CHANGE_ME_MINIMUM_16_CHARS_RANDOM
JWT_SECRET=CHANGE_ME_MINIMUM_16_CHARS_RANDOM

DHAN_CLIENT_ID=your_client_id
DHAN_ACCESS_TOKEN=your_access_token
DHAN_API_BASE_URL=https://api.dhan.co

MARKET_TIMEZONE=Asia/Kolkata
FEED_UNDERLYINGS=NIFTY,BANKNIFTY,FINNIFTY,MIDCPNIFTY,NIFTYNXT50,SENSEX,BANKEX,CRUDEOIL,NATURALGAS,COPPER,SILVER
SNAPSHOT_INTERVAL_MS=30000
# Optional BullMQ cron pattern. If set, this overrides SNAPSHOT_INTERVAL_MS.
# Example: every 30 seconds
# SNAPSHOT_CRON_PATTERN=*/30 * * * * *
MOCK_MARKET_FEED_ENABLED=false

# Required for email verification and password reset links.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password
EMAIL_FROM=Option Decode <no-reply@pytrade.co.in>
