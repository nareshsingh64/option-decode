{
  "name": "@option-decode/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "db:seed": "tsx src/seed.ts",
    "db:sync-lot-sizes": "tsc -p tsconfig.json && node dist/db/src/sync-lot-sizes.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@option-decode/analytics": "workspace:*",
    "@option-decode/types": "workspace:*",
    "@prisma/client": "^6.0.1"
  },
  "devDependencies": {
    "prisma": "^6.0.1",
    "typescript": "^5.7.2"
  }
}
