generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  SUBSCRIBER
  TRIAL
  FREE
}

enum OptionType {
  CE
  PE
}

enum PaperOrderStatus {
  PENDING
  FILLED
  CANCELLED
  REJECTED
}

enum PaperPositionStatus {
  OPEN
  CLOSED
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  passwordHash   String
  displayName    String?
  role           UserRole  @default(FREE)
  emailVerified  Boolean   @default(false)
  disabled       Boolean   @default(false)
  lastLoginAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  subscriptions  Subscription[]
  watchlists     Watchlist[]
  paperOrders    PaperOrder[]
  paperPositions PaperPosition[]
  alertThresholds AlertThreshold[]
  pushSubscriptions PushSubscription[]
  simAccounts    SimAccount[]
  tabAccess      UserTabAccess?
}

// Role-based tab access: which dashboard tabs a user may see. No row =
// the default tab set (Dashboard, Strike Matrix, Option Chain, Paper
// Trading). Admins implicitly see every tab regardless of this table.
model UserTabAccess {
  id        String   @id @default(cuid())
  userId    String   @unique
  tabs      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

model AlertThreshold {
  id               String   @id @default(cuid())
  userId           String
  underlyingSymbol String
  proximityPoints  Decimal  @db.Decimal(12, 2)
  pcrUpper         Decimal  @db.Decimal(10, 4)
  pcrLower         Decimal  @db.Decimal(10, 4)
  pressureWarning  Int      @default(55)
  pressureCritical Int      @default(62)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id])

  @@unique([userId, underlyingSymbol])
  @@index([underlyingSymbol])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @db.VarChar(512)
  p256dh    String   @db.VarChar(255)
  auth      String   @db.VarChar(255)
  userAgent String?  @db.VarChar(255)
  disabled  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, endpoint])
  @@index([userId, disabled])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  email     String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([email, expiresAt])
  @@index([tokenHash])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([email, expiresAt])
  @@index([tokenHash])
}

model Plan {
  id            String   @id @default(cuid())
  code          String   @unique
  name          String
  description   String?
  monthlyPrice  Decimal? @db.Decimal(10, 2)
  replayLimit   Int?
  realtime      Boolean  @default(false)
  premiumAlerts Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  subscriptions Subscription[]
}

model Subscription {
  id        String   @id @default(cuid())
  userId    String
  planId    String
  status    String
  startsAt  DateTime
  endsAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  plan      Plan     @relation(fields: [planId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, status])
}

model Underlying {
  id          String   @id @default(cuid())
  symbol      String   @unique
  displayName String
  exchange    String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  expiries    Expiry[]
}

model Expiry {
  id               String      @id @default(cuid())
  underlyingId     String
  expiryDate       DateTime    @db.Date
  expiryLabel      String
  active           Boolean     @default(true)
  underlying       Underlying  @relation(fields: [underlyingId], references: [id])
  snapshots        OptionChainSnapshot[]
  contracts        OptionContract[]

  @@unique([underlyingId, expiryDate])
  @@index([underlyingId, active, expiryDate])
}

model OptionContract {
  id           String     @id @default(cuid())
  expiryId     String
  optionType   OptionType
  strikePrice  Decimal    @db.Decimal(12, 2)
  securityId   String?
  lotSize      Int?
  tickSize     Decimal?   @db.Decimal(8, 4)
  active       Boolean    @default(true)
  expiry       Expiry     @relation(fields: [expiryId], references: [id])

  @@unique([expiryId, optionType, strikePrice])
  @@index([securityId])
}

model FnoLotSize {
  id            String   @id @default(cuid())
  symbol        String
  contractMonth DateTime @db.Date
  monthLabel    String
  lotSize       Int
  source        String   @default("DHAN")
  sourceUrl     String
  fetchedAt     DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([symbol, contractMonth])
  @@index([contractMonth])
}

model OptionChainSnapshot {
  id               String               @id @default(cuid())
  tradingDate      DateTime             @db.Date
  snapshotTime     DateTime
  underlyingSymbol String
  expiryId         String
  spotPrice        Decimal              @db.Decimal(12, 2)
  atmStrike        Decimal              @db.Decimal(12, 2)
  source           String               @default("DHAN")
  createdAt        DateTime             @default(now())
  expiry           Expiry               @relation(fields: [expiryId], references: [id])
  ticks            OptionContractTick[]
  pressureScores   PressureScore[]

  @@index([tradingDate, underlyingSymbol, snapshotTime])
  @@index([underlyingSymbol, expiryId, snapshotTime])
  @@index([underlyingSymbol, expiryId, tradingDate, snapshotTime])
  @@index([underlyingSymbol, snapshotTime])
}

model OptionContractTick {
  id                   String              @id @default(cuid())
  snapshotId           String
  tradingDate          DateTime            @db.Date
  tickTime             DateTime
  underlyingSymbol     String
  expiryLabel          String
  optionType           OptionType
  strikePrice          Decimal             @db.Decimal(12, 2)
  securityId           String?
  lastPrice            Decimal?            @db.Decimal(12, 2)
  bidPrice             Decimal?            @db.Decimal(12, 2)
  askPrice             Decimal?            @db.Decimal(12, 2)
  volume               Decimal?            @db.Decimal(20, 2)
  openInterest         Decimal?            @db.Decimal(20, 2)
  changeInOpenInterest Decimal?            @db.Decimal(20, 2)
  impliedVolatility    Decimal?            @db.Decimal(10, 4)
  deltaValue           Decimal?            @db.Decimal(10, 6)
  gammaValue           Decimal?            @db.Decimal(10, 6)
  thetaValue           Decimal?            @db.Decimal(10, 6)
  vegaValue            Decimal?            @db.Decimal(10, 6)
  snapshot             OptionChainSnapshot @relation(fields: [snapshotId], references: [id])

  @@index([snapshotId])
  @@index([tradingDate, underlyingSymbol, expiryLabel, optionType, strikePrice, tickTime])
  @@index([underlyingSymbol, expiryLabel, optionType, strikePrice, tickTime])
  @@index([underlyingSymbol, expiryLabel, tradingDate, optionType, strikePrice, tickTime])
  @@index([tickTime])
}

model PressureScore {
  id               String              @id @default(cuid())
  snapshotId       String
  underlyingSymbol String
  expiryLabel      String
  scoreTime        DateTime
  bullishPressure  Int
  bearishPressure  Int
  pcr              Decimal?            @db.Decimal(10, 4)
  maxPain          Decimal?            @db.Decimal(12, 2)
  payloadJson      Json?
  snapshot         OptionChainSnapshot @relation(fields: [snapshotId], references: [id])

  @@index([underlyingSymbol, expiryLabel, scoreTime])
}

model Watchlist {
  id        String   @id @default(cuid())
  userId    String
  name      String
  symbols   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model ReplaySession {
  id               String   @id @default(cuid())
  userId           String
  underlyingSymbol String
  expiryLabel      String
  tradingDate      DateTime @db.Date
  currentTime      DateTime
  speed            Int      @default(1)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId, tradingDate, underlyingSymbol])
}

model PaperOrder {
  id               String           @id @default(cuid())
  userId           String
  tradingDate      DateTime         @db.Date
  underlyingSymbol String
  expiryLabel      String
  action           String
  optionType       OptionType
  strikePrice      Decimal          @db.Decimal(12, 2)
  quantity         Int
  requestedPrice   Decimal          @db.Decimal(12, 2)
  filledPrice      Decimal?         @db.Decimal(12, 2)
  stopLoss         Decimal          @db.Decimal(12, 2)
  trailingStop     Boolean          @default(true)
  trailDistance    Decimal?         @db.Decimal(12, 2)
  targetPrice      Decimal          @db.Decimal(12, 2)
  status           PaperOrderStatus @default(PENDING)
  strategyName     String
  reasonText       String?          @db.Text
  // groupId links multiple legs submitted together in one order ticket
  // (e.g. a sold main leg + a bought hedge leg) into a single strategy.
  // Null/absent for ordinary single-leg orders placed before this feature
  // existed and for any order that isn't part of a multi-leg ticket.
  groupId          String?
  legRole          String           @default("MAIN")
  // Informational only, estimated at order placement using the requested
  // price and the last known securityId for this contract (works even
  // outside market hours - Dhan's margin calculator is a static SPAN/
  // exposure lookup, not a live quote). Refreshed with the real fill price
  // once the order actually fills (see PaperPosition.marginRequired).
  marginRequired   Decimal?         @db.Decimal(14, 2)
  marginBreakdown  Json?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  user             User             @relation(fields: [userId], references: [id])
  position         PaperPosition?

  @@index([userId, tradingDate, status])
  @@index([userId, createdAt])
  @@index([tradingDate, underlyingSymbol, status])
  @@index([status, createdAt])
  @@index([groupId])
}

model PaperPosition {
  id               String              @id @default(cuid())
  userId           String
  orderId          String              @unique
  tradingDate      DateTime            @db.Date
  underlyingSymbol String
  expiryLabel      String
  action           String
  optionType       OptionType
  strikePrice      Decimal             @db.Decimal(12, 2)
  quantity         Int
  entryPrice       Decimal             @db.Decimal(12, 2)
  currentPrice     Decimal             @db.Decimal(12, 2)
  stopLoss         Decimal             @db.Decimal(12, 2)
  trailingStop     Boolean             @default(true)
  trailDistance    Decimal?            @db.Decimal(12, 2)
  bestPrice        Decimal?            @db.Decimal(12, 2)
  // Consecutive refreshOpenPositionPrices cycles (~30s each) the WCI/DRC
  // "danger" signal has read against this position, back to back. The
  // dynamic trailing stop only lets a danger reading actually tighten the
  // stop once this reaches DANGER_STREAK_REQUIRED - a single noisy tick no
  // longer permanently ratchets the stop to breakeven.
  dangerSignalStreak Int               @default(0)
  targetPrice      Decimal             @db.Decimal(12, 2)
  status           PaperPositionStatus @default(OPEN)
  realizedPnl      Decimal             @default(0) @db.Decimal(14, 2)
  openedAt         DateTime
  closedAt         DateTime?
  exitReason       String?
  // Mirrors the originating order's leg-grouping, so open positions that
  // belong to the same multi-leg strategy can be displayed together.
  groupId          String?
  legRole          String              @default("MAIN")
  // Informational only (per user request) - Dhan's margin calculator
  // result captured at fill time, using actual fill prices/quantities.
  // Never used to block or size a paper trade.
  marginRequired   Decimal?            @db.Decimal(14, 2)
  marginBreakdown  Json?
  user             User                @relation(fields: [userId], references: [id])
  order            PaperOrder          @relation(fields: [orderId], references: [id])
  trade            PaperTrade?

  @@index([userId, tradingDate, status])
  @@index([userId, status, openedAt])
  @@index([tradingDate, underlyingSymbol, status])
  @@index([status, openedAt])
  @@index([groupId])
}

model PaperTrade {
  id          String        @id @default(cuid())
  positionId  String        @unique
  entryPrice  Decimal       @db.Decimal(12, 2)
  exitPrice   Decimal       @db.Decimal(12, 2)
  quantity    Int
  grossPnl    Decimal       @db.Decimal(14, 2)
  charges     Decimal       @default(0) @db.Decimal(14, 2)
  netPnl      Decimal       @db.Decimal(14, 2)
  exitReason  String
  closedAt    DateTime
  position    PaperPosition @relation(fields: [positionId], references: [id])

  @@index([closedAt])
}

// ============================================================
// Paper Trading Pro (seller strategy simulator) - fully separate
// from the existing PaperOrder/PaperPosition/PaperTrade module.
// Additive only; no existing table is modified.
// ============================================================

enum SimStrategyType {
  SHORT_STRADDLE
  BULL_PUT_SPREAD
  BEAR_CALL_SPREAD
  IRON_CONDOR
  NAKED_CALL
  NAKED_PUT
}

enum SimHorizon {
  INTRADAY
  WEEKLY
  MONTHLY
}

enum SimTradeStatus {
  OPEN
  CLOSED
  EXPIRED
  LIQUIDATED // Phase 3
}

enum SimLegSide {
  SELL
  BUY
}

enum SimExitRule {
  PROFIT_TARGET
  HARD_STOP_3X
  DTE_GAMMA
  EXPIRY_ITM
  DELTA_2X_INTRADAY // Phase 2
  MARGIN_CALL       // Phase 3
  DELIVERY_RISK     // Phase 3: stock option ITM inside expiry week
}

enum SimExitAction {
  FLAGGED      // Phase 1: surfaced in UI, user closes manually
  AUTO_CLOSED  // Phase 2
  LIQUIDATED   // Phase 3
}

model SimAccount {
  id              String     @id @default(cuid())
  userId          String
  name            String     @default("Default")
  startingCapital Decimal    @db.Decimal(16, 2)
  cash            Decimal    @db.Decimal(16, 2)
  // Sizing guardrail: max % of buying power a single trade may consume.
  maxTradeBpPct   Decimal    @default(5.00) @db.Decimal(5, 2)
  isActive        Boolean    @default(true)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  resetAt         DateTime?
  user            User       @relation(fields: [userId], references: [id])
  trades          SimTrade[]

  @@index([userId, isActive])
}

model SimTrade {
  id                String          @id @default(cuid())
  accountId         String
  strategyType      SimStrategyType
  underlyingSymbol  String
  expiryLabel       String
  expiryDate        DateTime        @db.Date
  horizon           SimHorizon
  lotSize           Int
  lots              Int
  status            SimTradeStatus  @default(OPEN)
  // Money amounts are total INR for the whole position (per-unit x lotSize x lots).
  netCredit         Decimal         @db.Decimal(14, 2)
  // Null = undefined risk (straddle / naked legs).
  maxLoss           Decimal?        @db.Decimal(14, 2)
  // Buying power effect reserved at entry.
  bpe               Decimal         @db.Decimal(16, 2)
  // Entry context for seller analytics / VRP tracking.
  underlyingAtEntry Decimal         @db.Decimal(12, 2)
  ivAtEntry         Decimal?        @db.Decimal(10, 4)
  hv20AtEntry       Decimal?        @db.Decimal(10, 4)
  ivHvRatio         Decimal?        @db.Decimal(10, 4)
  lowEdgeFlag       Boolean         @default(false) // IV/HV < 1.1 at entry
  // Phase 2: signal attribution from the Strike Matrix engine.
  entryWci          Decimal?        @db.Decimal(10, 4)
  entryDrcr         Decimal?        @db.Decimal(10, 4)
  signalRef         String?
  openedAt          DateTime        @default(now())
  closedAt          DateTime?
  exitReason        String?
  realizedPnl       Decimal?        @db.Decimal(14, 2)
  account           SimAccount      @relation(fields: [accountId], references: [id])
  legs              SimLeg[]
  snapshots         SimMtmSnapshot[]
  exitEvents        SimExitEvent[]

  @@index([accountId, status])
  @@index([underlyingSymbol, expiryLabel, status])
  @@index([status, expiryDate])
}

model SimLeg {
  id              String     @id @default(cuid())
  tradeId         String
  side            SimLegSide
  optionType      OptionType
  strikePrice     Decimal    @db.Decimal(12, 2)
  // Fill realism captured at entry (all per-unit premium values).
  midAtFill       Decimal    @db.Decimal(12, 2)
  bidAtFill       Decimal    @db.Decimal(12, 2)
  askAtFill       Decimal    @db.Decimal(12, 2)
  slippageChi     Decimal    @db.Decimal(4, 2) // 0.25 standard, 0.50 high-IV regime
  fillPrice       Decimal    @db.Decimal(12, 2) // SELL: mid - chi*spread, BUY: mid + chi*spread
  oiAtFill        Decimal?   @db.Decimal(20, 2)
  deltaAtFill     Decimal?   @db.Decimal(10, 6)
  ivAtFill        Decimal?   @db.Decimal(10, 4)
  // Per-unit premium paid/received to close this leg (set when trade closes).
  closeFillPrice  Decimal?   @db.Decimal(12, 2)
  // Phase 3: partial-fill tranches for large orders on thin strikes -
  // [{ lots, price }]; fillPrice above is the volume-weighted average.
  fillBreakdown   Json?
  trade           SimTrade   @relation(fields: [tradeId], references: [id])

  @@index([tradeId])
}

// Phase 1: one row per open trade per EOD run. Phase 2 adds intraday rows.
model SimMtmSnapshot {
  id        String   @id @default(cuid())
  tradeId   String
  ts        DateTime
  // Total INR cost to close the whole position now (slippage applied).
  closeCost Decimal  @db.Decimal(14, 2)
  pnl       Decimal  @db.Decimal(14, 2)
  netDelta  Decimal? @db.Decimal(12, 4)
  netGamma  Decimal? @db.Decimal(12, 6)
  netTheta  Decimal? @db.Decimal(12, 2)
  netVega   Decimal? @db.Decimal(12, 2)
  marginReq Decimal? @db.Decimal(16, 2)
  trade     SimTrade @relation(fields: [tradeId], references: [id])

  @@unique([tradeId, ts])
  @@index([ts])
}

model SimExitEvent {
  id          String        @id @default(cuid())
  tradeId     String
  rule        SimExitRule
  action      SimExitAction
  detail      String?       @db.VarChar(255)
  triggeredAt DateTime      @default(now())
  trade       SimTrade      @relation(fields: [tradeId], references: [id])

  @@index([tradeId, rule])
  @@index([triggeredAt])
}

model BacktestRun {
  id               String   @id @default(cuid())
  strategyName     String
  strategyVersion  String
  underlyingSymbol String
  dateFrom         DateTime @db.Date
  dateTo           DateTime @db.Date
  status           String
  configJson       Json?
  resultJson       Json?
  createdAt        DateTime @default(now())
  startedAt        DateTime?
  finishedAt       DateTime?
}
